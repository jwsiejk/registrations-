#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
TLS_ROOT="$ROOT_DIR/infra/docker/tls"
CA_DIR="$TLS_ROOT/ca"
ENV_FILE="$ROOT_DIR/.env"

if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
fi

DAYS="${TLS_CERT_VALIDITY_DAYS:-825}"

configure_msys_arg_conversion() {
  case "${OSTYPE:-}" in
    msys*|cygwin*)
      # Prevent Git Bash/MSYS from rewriting OpenSSL arguments and file paths.
      export MSYS_NO_PATHCONV=1
      export MSYS2_ARG_CONV_EXCL="*"
      ;;
  esac
}

openssl_path() {
  local path="$1"

  case "${OSTYPE:-}" in
    msys*|cygwin*)
      if command -v cygpath >/dev/null 2>&1; then
        cygpath -m "$path"
        return
      fi
      ;;
  esac

  echo "$path"
}

require_openssl() {
  if ! command -v openssl >/dev/null 2>&1; then
    echo "ERROR: openssl is required to generate local TLS assets."
    exit 1
  fi
}

generate_ca() {
  local req_config
  local openssl_err
  mkdir -p "$CA_DIR"
  req_config="$(mktemp "$CA_DIR/ca-req-XXXXXX.cnf")"
  openssl_err="$(mktemp "$CA_DIR/ca-req-XXXXXX.log")"
  trap 'rm -f "$req_config" "$openssl_err"' RETURN

  cat > "$req_config" <<EOT
[req]
distinguished_name=req_distinguished_name
prompt=no

[req_distinguished_name]
CN=registrations-local-postgres-ca
EOT

  if ! openssl req -x509 -new -nodes \
    -batch \
    -keyout "$(openssl_path "$CA_DIR/ca.key")" \
    -out "$(openssl_path "$CA_DIR/ca.crt")" \
    -sha256 \
    -days "$DAYS" \
    -config "$(openssl_path "$req_config")" >/dev/null 2>"$openssl_err"; then
    echo "ERROR: OpenSSL failed while generating local CA certificate." >&2
    cat "$openssl_err" >&2
    return 1
  fi
  chmod 600 "$CA_DIR/ca.key"
  chmod 644 "$CA_DIR/ca.crt"
}

generate_service_cert() {
  local service="$1"
  local service_dir="$TLS_ROOT/$service"
  local cn="postgres-${service}"
  local ext_file="$service_dir/server.ext"
  local req_config

  mkdir -p "$service_dir"

  cat > "$ext_file" <<EOT
authorityKeyIdentifier=keyid,issuer
basicConstraints=CA:FALSE
keyUsage=digitalSignature,keyEncipherment
extendedKeyUsage=serverAuth
subjectAltName=DNS:postgres-${service},DNS:localhost,IP:127.0.0.1
EOT

  req_config="$(mktemp "$service_dir/server-req-XXXXXX.cnf")"
  cat > "$req_config" <<EOT
[req]
distinguished_name=req_distinguished_name
prompt=no

[req_distinguished_name]
CN=$cn
EOT

  openssl genrsa -out "$(openssl_path "$service_dir/server.key")" 2048 >/dev/null 2>&1
  openssl req -new \
    -batch \
    -key "$(openssl_path "$service_dir/server.key")" \
    -out "$(openssl_path "$service_dir/server.csr")" \
    -config "$(openssl_path "$req_config")" >/dev/null 2>&1
  openssl x509 -req -in "$(openssl_path "$service_dir/server.csr")" \
    -CA "$(openssl_path "$CA_DIR/ca.crt")" \
    -CAkey "$(openssl_path "$CA_DIR/ca.key")" \
    -CAcreateserial \
    -out "$(openssl_path "$service_dir/server.crt")" \
    -days "$DAYS" \
    -sha256 \
    -extfile "$(openssl_path "$ext_file")" >/dev/null 2>&1

  cp "$CA_DIR/ca.crt" "$service_dir/ca.crt"

  chmod 600 "$service_dir/server.key"
  chmod 644 "$service_dir/server.crt" "$service_dir/ca.crt"

  rm -f "$service_dir/server.csr" "$ext_file" "$req_config"
}

require_openssl
configure_msys_arg_conversion
rm -rf "$TLS_ROOT"
mkdir -p "$TLS_ROOT"

generate_ca
for service in crm erp warehouse; do
  generate_service_cert "$service"
done

echo "Generated local Postgres TLS assets in: $TLS_ROOT"
