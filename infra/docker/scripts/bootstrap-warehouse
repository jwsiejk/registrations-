#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
COMPOSE_FILE="$ROOT_DIR/infra/docker/compose.yaml"
ENV_FILE="$ROOT_DIR/.env"

if [[ ! -f "$ENV_FILE" ]]; then
  echo "ERROR: Required environment file is missing: $ENV_FILE"
  echo "Create it from the template first: cp .env.example .env"
  exit 1
fi

docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" exec -T postgres-warehouse bash -lc '
set -euo pipefail
for sql_file in /opt/bootstrap/warehouse/bootstrap/*.sql; do
  echo "[warehouse bootstrap] applying: ${sql_file}"
  psql -v ON_ERROR_STOP=1 --username "$POSTGRES_USER" --dbname "$POSTGRES_DB" -f "$sql_file"
done
'

echo "Warehouse bootstrap complete."
